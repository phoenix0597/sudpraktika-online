# Local default:
#   http://localhost:8080/
SITE_ADDRESS=:80
SITE_HTTP_PORT=8080
SITE_HTTPS_PORT=8443

# Production example:
# SITE_ADDRESS=sudpraktika-online.ru
# SITE_HTTP_PORT=80
# SITE_HTTPS_PORT=443
#
# For automatic public HTTPS Caddy needs:
# - DNS A/AAAA record pointing to the server;
# - inbound ports 80 and 443 open;
# - persistent caddy_data/caddy_config volumes.
