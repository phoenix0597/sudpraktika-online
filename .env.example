# Local default:
#   ZPP: http://localhost:8080/
#   DDU: http://localhost:8081/
ZPP_SITE_ADDRESS=:80
DDU_SITE_ADDRESS=:81
ZPP_DEV_HTTP_PORT=8080
DDU_DEV_HTTP_PORT=8081
SITE_HTTPS_PORT=8443
SITE_PUBLIC_URL=https://sudpraktika-online.ru
ZPP_SITE_ROOT=./site_prototype
DDU_SITE_ROOT=./site_dev/ddu-placeholder

# Production example:
# ZPP_SITE_ADDRESS=sudpraktika-online.ru
# ZPP_DEV_HTTP_PORT=80
# SITE_HTTPS_PORT=443
# SITE_PUBLIC_URL=https://sudpraktika-online.ru
# ZPP_SITE_ROOT=./site_prototype
# DDU_SITE_ROOT=./dist/ddu-online.ru
#
# For automatic public HTTPS Caddy needs:
# - DNS A/AAAA record pointing to the server;
# - inbound ports 80 and 443 open;
# - persistent caddy_data/caddy_config volumes.
