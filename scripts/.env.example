# Скопируйте в .env и заполните. .env НИКОГДА не попадает в репозиторий (.gitignore).

# API-ключ Wordstat API (Yandex Cloud / AI Studio), привязанный к сервисному аккаунту
# с ролью search-api.webSearch.user. Получение: AI Studio → Создать API-ключ.
YANDEX_API_KEY=вставьте_ключ_сюда

# folderId облака Yandex Cloud (если требуется эндпоинтом)
YANDEX_FOLDER_ID=

# Дневной бюджет запросов Wordstat (буфер безопасности под лимит 1000/сутки).
# Скрипт откажется стартовать, если остаток лимита на сегодня меньше планируемого числа запросов.
WORDSTAT_DAILY_BUDGET=950
